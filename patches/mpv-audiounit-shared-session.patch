 struct priv {
     AudioUnit audio_unit;
     double device_latency;
+    bool session_acquired;
+    bool skip_session_management;
 };
 
+static pthread_mutex_t audiounit_session_lock = PTHREAD_MUTEX_INITIALIZER;
+static int audiounit_session_use_count;
+
 static OSStatus au_get_ary(AudioUnit unit, AudioUnitPropertyID inID, AudioUnitScope inScope, AudioUnitElement inElement, void **data, UInt32 *outDataSize)
 {
     OSStatus err;
@@ -81,8 +88,60 @@
     talloc_free(layout);
     return new_layout;
 }
+
+static void acquire_audio_session(struct ao *ao, NSInteger pref_channels)
+{
+    struct priv *p = ao->priv;
+    AVAudioSession *instance = AVAudioSession.sharedInstance;
+
+    pthread_mutex_lock(&audiounit_session_lock);
+
+    if (audiounit_session_use_count == 0) {
+        [instance setCategory:AVAudioSessionCategoryPlayback
+                  withOptions:AVAudioSessionCategoryOptionMixWithOthers
+                        error:nil];
+        [instance setMode:AVAudioSessionModeMoviePlayback error:nil];
+        [instance setActive:YES error:nil];
+        [instance setPreferredOutputNumberOfChannels:pref_channels error:nil];
+    }
+
+    audiounit_session_use_count++;
+    p->session_acquired = true;
+
+    MP_VERBOSE(ao, "audio session users: %d\n", audiounit_session_use_count);
+
+    pthread_mutex_unlock(&audiounit_session_lock);
+}
+
+static void release_audio_session(struct ao *ao)
+{
+    struct priv *p = ao->priv;
+
+    if (!p->session_acquired)
+        return;
+
+    pthread_mutex_lock(&audiounit_session_lock);
 
+    if (audiounit_session_use_count > 0)
+        audiounit_session_use_count--;
+    else
+        MP_WARN(ao, "audio session reference count underflow\n");
 
+    p->session_acquired = false;
+
+    if (audiounit_session_use_count == 0) {
+        [AVAudioSession.sharedInstance
+            setActive:NO
+            withOptions:AVAudioSessionSetActiveOptionNotifyOthersOnDeactivation
+            error:nil];
+    } else {
+        MP_VERBOSE(ao, "keeping audio session active for %d other user(s)\n",
+                   audiounit_session_use_count);
+    }
+
+    pthread_mutex_unlock(&audiounit_session_lock);
+}
