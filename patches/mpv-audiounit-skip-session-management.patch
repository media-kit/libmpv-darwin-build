From: Igor Khramtsov <igor.khramtsov@proton.me>
Subject: [PATCH] ao_audiounit: add --audiounit-skip-session-management option

Adds an AO-scoped boolean option `audiounit-skip-session-management`
(default: no). When enabled, the AudioUnit backend skips all
AVAudioSession state mutations in init/uninit: setCategory,
setActive:YES, and the setActive:NO/notifyOthersOnDeactivation pair.

The default-off behavior is unchanged.

This is for embedders that centralize AVAudioSession ownership across
multiple audio consumers (e.g. game audio, voice chat, in-app video).
Without this option, every Player init/dispose cycle forces the global
session back to Playback + active, which interferes with other
consumers' configuration and tears down their audio on dispose.

setMode:MoviePlayback is intentionally left unconditional. Unlike
setCategory it does not deactivate the session as a side effect, and
applies within whatever category the embedder has configured; embedders
that need a different mode can reassert it after Player init.

Note for downstream maintainers: when stacking this on top of
mpv-mix-with-others.patch, this patch must apply second — its
setCategory context includes the `.mixWithOthers` option that the other
patch introduces.

--- a/audio/out/ao_audiounit.m
+++ b/audio/out/ao_audiounit.m
@@ -33,6 +33,7 @@
 struct priv {
     AudioUnit audio_unit;
     double device_latency;
+    bool skip_session_management;
 };

 static OSStatus au_get_ary(AudioUnit unit, AudioUnitPropertyID inID, AudioUnitScope inScope, AudioUnitElement inElement, void **data, UInt32 *outDataSize)
@@ -115,9 +116,11 @@ static bool init_audiounit(struct ao *ao)

     MP_VERBOSE(ao, "max channels: %ld, requested: %d\n", maxChannels, (int)ao->channels.num);

-    [instance setCategory:AVAudioSessionCategoryPlayback withOptions:AVAudioSessionCategoryOptionMixWithOthers error:nil];
+    if (!p->skip_session_management)
+        [instance setCategory:AVAudioSessionCategoryPlayback withOptions:AVAudioSessionCategoryOptionMixWithOthers error:nil];
     [instance setMode:AVAudioSessionModeMoviePlayback error:nil];
-    [instance setActive:YES error:nil];
+    if (!p->skip_session_management)
+        [instance setActive:YES error:nil];
     [instance setPreferredOutputNumberOfChannels:prefChannels error:nil];

     AudioComponentDescription desc = (AudioComponentDescription) {
@@ -230,10 +233,12 @@ static void uninit(struct ao *ao)
     AudioUnitUninitialize(p->audio_unit);
     AudioComponentInstanceDispose(p->audio_unit);

-    [AVAudioSession.sharedInstance
-        setActive:NO
-        withOptions:AVAudioSessionSetActiveOptionNotifyOthersOnDeactivation
-        error:nil];
+    if (!p->skip_session_management) {
+        [AVAudioSession.sharedInstance
+            setActive:NO
+            withOptions:AVAudioSessionSetActiveOptionNotifyOthersOnDeactivation
+            error:nil];
+    }
 }

 static int init(struct ao *ao)
@@ -257,4 +262,9 @@ const struct ao_driver audio_out_audiounit = {
     .reset          = stop,
     .start          = start,
     .priv_size      = sizeof(struct priv),
+    .options        = (const struct m_option[]) {
+        {"skip-session-management", OPT_BOOL(skip_session_management)},
+        {0}
+    },
+    .options_prefix = "audiounit",
 };
